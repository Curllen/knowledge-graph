ad", "callee": "useEffect", "is_member_call": false, "source_file": "/workspace/spring-ai-alibaba-studio/agent-chat-ui/src/components/thread/index.tsx", "source_location": "L272"}, {"caller_nid": "thread_index_thread", "callee": "useRef", "is_member_call": false, "source_file": "/workspace/spring-ai-alibaba-studio/agent-chat-ui/src/components/thread/index.tsx", "source_location": "L284"}, {"caller_nid": "thread_index_thread", "callee": "useRef", "is_member_call": false, "source_file": "/workspace/spring-ai-alibaba-studio/agent-chat-ui/src/components/thread/index.tsx", "source_location": "L299"}, {"caller_nid": "thread_index_thread", "callee": "useEffect", "is_member_call": false, "source_file": "/workspace/spring-ai-alibaba-studio/agent-chat-ui/src/components/thread/index.tsx", "source_location": "L300"}, {"caller_nid": "thread_index_thread", "callee": "cn", "is_member_call": false, "source_file": "/workspace/spring-ai-alibaba-studio/agent-chat-ui/src/components/thread/index.tsx", "source_location": "L374"}, {"caller_nid": "thread_index_thread", "callee": "cn", "is_member_call": false, "source_file": "/workspace/spring-ai-alibaba-studio/agent-chat-ui/src/components/thread/index.tsx", "source_location": "L380"}, {"caller_nid": "thread_index_thread", "callee": "cn", "is_member_call": false, "source_file": "/workspace/spring-ai-alibaba-studio/agent-chat-ui/src/components/thread/index.tsx", "source_location": "L560"}, {"caller_nid": "thread_index_thread", "callee": "(() => {\n                    const filteredMessages = messages.filter((m) => !m.id?.startsWith(DO_NOT_RENDER_ID_PREFIX));\n                    console.log('[Thread] Rendering messages:', {\n                      total: messages.length,\n                      filtered: filteredMessages.length,\n                      messages: filteredMessages.map(m => ({\n                        id: m.id,\n                        type: m.message.messageType\n                      }))\n                    });\n                    return filteredMessages.map((message, index) => {\n                      console.log('[Thread] Rendering message:', message.message.messageType, message);\n\n                      const messageType = message.message.messageType;\n                      const key = message.id || `${messageType}-${index}`;\n\n                      // Hide tool-related messages if hideToolCalls is enabled\n                      if (hideToolCalls && (\n                        messageType === \"tool-request\" ||\n                        messageType === \"tool-confirm\" ||\n                        messageType === \"tool\"\n                      )) {\n                        console.log('[Thread] Hiding tool message due to hideToolCalls:', messageType);\n                        return null;\n                      }\n\n                      switch (messageType) {\n                        case \"user\":\n                          return <HumanMessage key={key} message={message} />;\n\n                        case \"assistant\":\n                          return <AssistantMessage key={key} message={message} />;\n\n                        case \"tool-request\":\n                          return <ToolRequestMessage key={key} message={message} />;\n\n                        case \"tool-confirm\":\n                          return <ToolRequestConfirmMessage key={key} message={message} />;\n\n                        case \"tool\":\n                          return <ToolResponseMessage key={key} message={message} />;\n\n                        default:\n                          console.log('[Thread] Unknown message type:', messageType);\n                          return null;\n                      }\n                    });\n                  })", "is_member_call": false, "source_file": "/workspace/spring-ai-alibaba-studio/agent-chat-ui/src/components/thread/index.tsx", "source_location": "L568"}, {"caller_nid": "thread_index_thread", "callee": "cn", "is_member_call": false, "source_file": "/workspace/spring-ai-alibaba-studio/agent-chat-ui/src/components/thread/index.tsx", "source_location": "L636"}, {"caller_nid": "thread_index_thread", "callee": "cn", "is_member_call": false, "source_file": "/workspace/spring-ai-alibaba-studio/agent-chat-ui/src/components/thread/index.tsx", "source_location": "L670"}, {"caller_nid": "thread_index_thread", "callee": "trim", "is_member_call": true, "source_file": "/workspace/spring-ai-alibaba-studio/agent-chat-ui/src/components/thread/index.tsx", "source_location": "L715"}]}